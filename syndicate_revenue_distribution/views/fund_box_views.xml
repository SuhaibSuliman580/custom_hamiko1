<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_syndicate_fund_box_tree" model="ir.ui.view">
        <field name="name">syndicate.fund.box.tree</field>
        <field name="model">syndicate.fund.box</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="income_account_id"/>
                <field name="analytic_account_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_syndicate_fund_box_form" model="ir.ui.view">
        <field name="name">syndicate.fund.box.form</field>
        <field name="model">syndicate.fund.box</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="income_account_id"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_syndicate_fund_box" model="ir.actions.act_window">
        <field name="name">Fund Boxes</field>
        <field name="res_model">syndicate.fund.box</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_syndicate_root"
              name="Syndicate"
              sequence="90"/>

    <menuitem id="menu_syndicate_configuration"
              name="Configuration"
              parent="menu_syndicate_root"
              sequence="10"/>

    <menuitem id="menu_syndicate_fund_box"
              name="Fund Boxes"
              parent="menu_syndicate_configuration"
              action="action_syndicate_fund_box"
              sequence="20"/>

</odoo>
