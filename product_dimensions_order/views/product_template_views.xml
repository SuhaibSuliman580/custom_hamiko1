<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_template_form_dimensions" model="ir.ui.view">
        <field name="name">product.template.form.dimensions</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//field[@name='categ_id']" position="after">
                <field name="markaz_thickness"/>
                <field name="markaz_width"/>
            </xpath>
        </field>
    </record>
</odoo>
