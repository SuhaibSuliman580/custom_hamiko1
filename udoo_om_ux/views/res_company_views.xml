<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_form_inherit_om" model="ir.ui.view">
        <field name="name">res.company.form.inherit.om</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='social_media']" position="before">
                <group string="Appearance Config">
                    <field name="menus_preset" options="{'no_create': True}" widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
