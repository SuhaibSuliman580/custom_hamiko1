<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="udoo_om_ux.AppearanceConfig">
        <Dialog title.translate="Appearance" size="'md'">
            <div class="g-3 row u_appearance">
                <div class="col-lg-12">
                    <div class="g-col-sm-2">
                        <div class="mb-3 text-uppercase text-primary fw-bolder small">Navigation</div>
                    </div>
                    <div class="card border-0 flex-md-grow-1">
                        <div class="position-relative h-100">
                            <div class="overflow-auto w-100 h-100">
                                <div data-tooltip="When the sidebar is enabled, the horizontal menu will automatically be hidden.">
                                    <CheckBox value="uo.ps_auto_hmenu" onChange.bind="(isChecked) => this.onUoOptionChanged('ps_auto_hmenu', isChecked)">
                                        Auto hide horizontal menu 
                                    </CheckBox>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-12">
                    <div class="g-col-sm-2">
                        <div class="mb-3 text-uppercase text-primary fw-bolder small">Layout</div>
                    </div>
                    <div class="card border-0 flex-md-grow-1">
                        <div class="card-title text-uppercase fw-bolder smaller">User Interface Size</div>
                        <div class="position-relative h-100 mt-1">
                            <div class="overflow-auto w-100 h-100">
                                <div t-foreach="uiSizes" t-as="ks" t-key="ks_index" t-att-data-tooltip="uiTooltip[ks]" class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="inlineRadioOptions"
                                        t-on-change="() => this.onUiSize(uiSizes[ks])"
                                        t-attf-id="ui_{{ks}}"
                                        t-att-checked="ue.sett_uisize == uiSizes[ks] or uiSizes[ks] == uiUtils.getSize()"
                                        t-att-value="uiSizes[ks]"/>
                                    <label class="form-check-label" t-attf-for="ui_{{ks}}" t-esc="ks"></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-12">
                    <div class="mb-3 text-uppercase text-primary fw-bolder small">Look &amp; Feel</div>
                    <div class="card border-0 flex-md-grow-1 u_primary">
                        <div class="card-title text-uppercase fw-bolder smaller">Primary Color</div>
                        <div class="position-relative h-100">
                            <div class="overflow-auto w-100 h-100">
                                <div class="d-flex flex-wrap align-items-center gap-2 mt-1">
                                    <div t-foreach="scheme_data" t-as="pc" t-key="pc_index" t-if="pc.color" class="rounded-pill" t-att-class="{'border': state.color_shade == pc.code}">
                                        <div t-on-click="() => { state.color_shade = pc.code; }" class="btn rounded-pill color-node-md" t-att-data-tooltip="pc.title" t-attf-style="margin:3px; background: {{pc.color}};"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card border-0 flex-md-grow-1 mt-4">
                        <div class="card-title text-uppercase fw-bolder smaller">Theme Preset</div>
                        <div class="position-relative h-100">
                            <div class="overflow-auto w-100 h-100">
                                <div class="list-group">
                                    <a t-foreach="scheme_data" t-as="preset" t-key="preset_index" t-if="preset.scheme" class="list-group-item list-group-item-action">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex flex-fill flex-column text-truncate">
                                                <span t-out="preset.title" class="fw-bold d-inline-block text-truncate"/>
                                                <span t-out="preset.subtitle" class="fs-6 d-inline-block text-muted text-truncate"/>
                                            </div>
                                            <code t-out="preset.creator" class="d-flex align-self-start text-muted"/>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2 mt-2">
                                            <div t-foreach="preset.scheme" t-as="scheme" t-key="scheme_index" t-attf-style="background: {{scheme}};" t-att-data-tooltip="preset.scheme[scheme]" class="color-node rounded-circle" />
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div t-if="user.isSystem" class="dev_area">
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary me-auto" t-on-click="props.close">Close</button>
                <button class="btn btn-primary" t-on-click="confirm">Sync your options</button>
            </t>
        </Dialog>
    </t>
</templates>