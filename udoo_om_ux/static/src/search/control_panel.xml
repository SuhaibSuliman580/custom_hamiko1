<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="web.ControlPanel" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_control_panel_navigation')]" position="inside">
            <t t-set-slot="control-panel-navigation-additional">
                <nav class="u_layter">
                    <Dropdown togglerClass="'btn btn-outline-primary d-flex u_layter_action'" beforeOpen="() => this.initLayter()">
                        <t t-set-slot="toggler">
                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M15.1986 9.94447C14.7649 9.5337 14.4859 8.98613 14.4085 8.39384L14.0056 5.31138L11.275 6.79724C10.7503 7.08274 10.1433 7.17888 9.55608 7.06948L6.49998 6.50015L7.06931 9.55625C7.17871 10.1435 7.08257 10.7505 6.79707 11.2751L5.31121 14.0057L8.39367 14.4086C8.98596 14.4861 9.53353 14.7651 9.94431 15.1987L12.0821 17.4557L13.4178 14.6486C13.6745 14.1092 14.109 13.6747 14.6484 13.418L17.4555 12.0823L15.1986 9.94447ZM15.2238 15.5079L13.0111 20.1581C12.8687 20.4573 12.5107 20.5844 12.2115 20.442C12.1448 20.4103 12.0845 20.3665 12.0337 20.3129L8.49229 16.5741C8.39749 16.474 8.27113 16.4096 8.13445 16.3918L3.02816 15.7243C2.69958 15.6814 2.46804 15.3802 2.51099 15.0516C2.52056 14.9784 2.54359 14.9075 2.5789 14.8426L5.04031 10.3192C5.1062 10.1981 5.12839 10.058 5.10314 9.92253L4.16 4.85991C4.09931 4.53414 4.3142 4.22086 4.63997 4.16017C4.7126 4.14664 4.78711 4.14664 4.85974 4.16017L9.92237 5.10331C10.0579 5.12855 10.198 5.10637 10.319 5.04048L14.8424 2.57907C15.1335 2.42068 15.4979 2.52825 15.6562 2.81931C15.6916 2.88421 15.7146 2.95507 15.7241 3.02833L16.3916 8.13462C16.4095 8.2713 16.4739 8.39766 16.5739 8.49245L20.3127 12.0338C20.5533 12.2617 20.5636 12.6415 20.3357 12.8821C20.2849 12.9357 20.2246 12.9795 20.1579 13.0112L15.5078 15.224C15.3833 15.2832 15.283 15.3835 15.2238 15.5079ZM16.0206 17.435L17.4348 16.0208L21.6775 20.2634L20.2633 21.6776L16.0206 17.435Z"></path>
                            </svg>
                        </t>
                        <DropdownItem t-if="!env.searchModel?._context.splited_form" class="'d-flex align-items-center'" onSelected="doRefresh">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-luci text-dodger lucide lucide-rotate-ccw"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            <t>Refresh Data</t>
                        </DropdownItem>
                        <DropdownItem t-if="!env.inDialog and hasChatter" class="'d-flex align-items-center'" onSelected="() => env.bus.trigger('LYT:TCTT')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-luci text-dodger lucide lucide-message-square-code"><path d="M10 7.5 8 10l2 2.5"/><path d="m14 7.5 2 2.5-2 2.5"/><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <t>Toggle Chatter</t>
                        </DropdownItem>
                        <DropdownItem t-if="!env.inDialog and hasChatter and hasAttachmentPreview !== true" onSelected="() => this.switchAside()">
                            <i t-if="store.focusChatter" class="me-2 ri-st text-dodger ri-rectangle-line"/>
                            <i t-else="" class="me-2 ri-st text-dodger ri-layout-right-2-line"/>
                            <t t-if="store.focusChatter">Bottom-side Chatter</t>
                            <t t-else="">Right-edge Chatter</t>
                        </DropdownItem>
                        <DropdownItem t-if="hasList" class="'d-flex align-items-center'" onSelected="() => env.bus.trigger('TREE:OMCL')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-luci text-dodger lucide lucide-ruler"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/><path d="m14.5 12.5 2-2"/><path d="m11.5 9.5 2-2"/><path d="m8.5 6.5 2-2"/><path d="m17.5 15.5 2-2"/></svg>
                            <t>Autosize Columns</t>
                        </DropdownItem>
                        <span t-if="onKanban" t-on-click.prevent="switchFloorMode" class="dropdown-item" role="menuitem" tabindex="0">
                            <div class="pe-none o-checkbox form-check form-switch d-flex align-items-center flex-row-reverse justify-content-between p-0 w-100 mb-0">
                                <input id="u_DropinMode" type="checkbox" class="form-check-input ms-3 mt-0" t-att-checked="ui.dropinMode or state.dropinMode"/>
                                <label class="user-select-none d-flex align-items-center" for="u_DropinMode">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-luci text-dodger lucide lucide-picture-in-picture-2"><path d="M21 9V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10c0 1.1.9 2 2 2h4"/><rect width="10" height="7" x="12" y="13" rx="2"/></svg>
                                    <t>Quick Pop-up View</t>
                                </label>
                            </div>
                        </span>
                    </Dropdown>
                </nav>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('o_control_panel_main_buttons')]//div[hasclass('d-xl-inline-flex')]/t" position="after">
            <span t-if="breadcrumbs.length > 1" class="btn btn-outline-primary px-2 u_btn_back" t-on-click.prevent.stop="backTrick">
                <i class="ri-lr ri-arrow-left-line" style="line-height: 0"/>
            </span>
        </xpath>
    </t>

    <t t-inherit="web.Breadcrumbs" t-inherit-mode="extension">
        <xpath expr="//Dropdown[contains(@togglerClass,'btn-light btn-sm px-1 p-0')]" position="attributes">
            <attribute name="togglerClass" add="' lh-1'" separator="+"/>
        </xpath>
    </t>

</templates>