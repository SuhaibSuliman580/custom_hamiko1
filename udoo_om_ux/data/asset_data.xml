<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="custom_dark_scss" model="ir.asset">
            <field name="name">[OMUX] Custom Dark Theme Variables</field>
            <field name="bundle">web.assets_web_dark</field>
            <field name="directive">after</field>
            <field name="target">udoo_om_ux/static/src/scss/style_variables.scss</field>
            <field name="path">udoo_om_ux/static/src/scss/omux/dark.scss</field>
            <field name="sequence" eval="16"/>
        </record>

        <record id="remove_light_in_dark" model="ir.asset">
            <field name="name">[OMUX] Remove Light in Dark Bundle</field>
            <field name="bundle">web.assets_web_dark</field>
            <field name="directive">remove</field>
            <field name="path">udoo_om_ux/static/src/scss/omux/light.scss</field>
            <field name="sequence" eval="16"/>
        </record>
    </data>
</odoo>
