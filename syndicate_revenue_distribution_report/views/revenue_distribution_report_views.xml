
<odoo>
    <record id="view_report_tree" model="ir.ui.view">
        <field name="name">revenue.distribution.report.tree</field>
        <field name="model">syndicate.revenue.distribution.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="move_name"/>
                <field name="product_id"/>
                <field name="account_id"/>
                <field name="amount"/>
            </tree>
        </field>
    </record>

    <record id="action_report" model="ir.actions.act_window">
        <field name="name">Revenue Distribution Report</field>
        <field name="res_model">syndicate.revenue.distribution.report</field>
        <field name="view_mode">tree,pivot,graph</field>
    </record>

    <menuitem id="menu_report_root" name="Syndicate Reports"/>
    <menuitem id="menu_report" name="Revenue Distribution"
              parent="menu_report_root"
              action="action_report"/>
</odoo>
